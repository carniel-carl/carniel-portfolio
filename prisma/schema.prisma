generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model About {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  bio           String
  profilePicUrl String
  resumeUrl     String
  updatedAt     DateTime @updatedAt
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  tag         String?
  description String
  img         String
  mediaType   String   @default("image")
  live        String?
  code        String?
  stack       String[]
  featured    Boolean  @default(false)
  visible     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  title    String
  iconName String
  iconLib  String
  order    Int    @default(0)
}

model SocialLink {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
  link String
}

model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
